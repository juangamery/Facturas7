<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Facturas - Facturación</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-white">
  <!-- NAVBAR -->
  <nav class="sticky top-0 z-50 border-b border-slate-800 bg-slate-900/95 backdrop-blur">
    <div class="flex items-center justify-between px-6 py-4 max-w-7xl mx-auto w-full">
      <a class="text-xl font-bold text-blue-400" href="/admin/dashboard">📱 Facturación</a>
      <div class="flex gap-2">
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800 transition" href="/admin/dashboard">📊 Dashboard</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800 transition" href="/admin/clientes">👥 Clientes</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-white bg-slate-800 rounded-lg" href="/admin/facturas">📄 Facturas</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-red-400 hover:text-red-300 hover:bg-slate-800 transition" href="/admin/logout">🚪 Salir</a>
      </div>
    </div>
  </nav>

  <!-- MAIN CONTENT -->
  <main class="p-8 max-w-7xl mx-auto">
    <!-- HEADER -->
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-4xl font-bold text-white mb-2">📋 Historial de Facturas</h1>
        <p class="text-slate-400">Revisa todas tus facturas emitidas</p>
      </div>
      <a href="/admin/facturas/nuevo" class="px-6 py-3 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-semibold transition shadow-lg hover:shadow-blue-600/50">+ Nueva Factura</a>
    </div>

    <!-- SEARCH -->
    <div class="mb-8 bg-slate-800/50 border border-slate-700 rounded-lg p-6">
      <form method="GET" action="/admin/facturas" class="flex gap-2">
        <input
          type="text"
          name="q"
          placeholder="Buscar por cliente o número de factura..."
          value="<%= busqueda %>"
          class="flex-1 px-4 py-2 rounded-lg bg-slate-900 border border-slate-600 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none"
        >
        <button type="submit" class="px-6 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium transition">Buscar</button>
      </form>
    </div>

    <!-- TABLE -->
    <div class="bg-slate-800/50 border border-slate-700 rounded-lg overflow-hidden">
      <% if (facturas && facturas.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="border-b border-slate-700 bg-slate-800/80">
            <tr>
              <th class="text-left px-6 py-4 text-slate-300 font-semibold text-sm">Número</th>
              <th class="text-left px-6 py-4 text-slate-300 font-semibold text-sm">Cliente</th>
              <th class="text-left px-6 py-4 text-slate-300 font-semibold text-sm">Fecha</th>
              <th class="text-left px-6 py-4 text-slate-300 font-semibold text-sm">Concepto</th>
              <th class="text-left px-6 py-4 text-slate-300 font-semibold text-sm">Importe</th>
              <th class="text-left px-6 py-4 text-slate-300 font-semibold text-sm">Origen</th>
              <th class="text-left px-6 py-4 text-slate-300 font-semibold text-sm">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% facturas.forEach(factura => { %>
            <tr class="border-b border-slate-700/50 hover:bg-slate-700/20 transition">
              <td class="px-6 py-4">
                <code class="bg-slate-900 px-2 py-1 rounded text-sm text-blue-300 font-semibold"><%= factura.numero_factura %></code>
              </td>
              <td class="px-6 py-4 font-medium"><%= factura.nombre %></td>
              <td class="px-6 py-4 text-slate-400"><%= new Date((factura.creado_en || 0) * 1000).toLocaleDateString('es-AR') %></td>
              <td class="px-6 py-4 text-slate-400"><%= (factura.concepto || '-').substring(0, 35) %><%if((factura.concepto || '').length > 35){%>...<%}%></td>
              <td class="px-6 py-4 font-semibold text-green-400">$<%= (factura.importe || 0).toLocaleString('es-AR') %></td>
              <td class="px-6 py-4">
                <span class="px-3 py-1 rounded-lg border text-xs font-medium
                  <% if (factura.origen === 'texto') { %>
                    bg-blue-600/20 text-blue-300 border-blue-500/30
                  <% } else if (factura.origen === 'imagen') { %>
                    bg-purple-600/20 text-purple-300 border-purple-500/30
                  <% } else if (factura.origen === 'audio') { %>
                    bg-green-600/20 text-green-300 border-green-500/30
                  <% } else { %>
                    bg-slate-600/20 text-slate-300 border-slate-500/30
                  <% } %>
                ">
                  <% if (factura.origen === 'texto') { %>
                    📝 Texto
                  <% } else if (factura.origen === 'imagen') { %>
                    📸 Imagen
                  <% } else if (factura.origen === 'audio') { %>
                    🎤 Audio
                  <% } else { %>
                    <%= factura.origen %>
                  <% } %>
                </span>
              </td>
              <td class="px-6 py-4">
                <% if (factura.pdf_path) { %>
                <a href="/admin/facturas-descargar/<%= factura.id %>" class="px-3 py-1 bg-green-600 hover:bg-green-700 rounded text-sm font-medium transition">Descargar</a>
                <% } else { %>
                <span class="text-slate-500 text-sm">—</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <div class="text-center py-12 text-slate-400">
        <p class="text-3xl mb-4">📄</p>
        <p class="text-lg">Sin facturas registradas</p>
        <p class="text-sm mt-2">Las facturas aparecerán aquí cuando las emitas por WhatsApp o manualmente</p>
        <a href="/admin/clientes" class="inline-block mt-4 px-6 py-2 bg-blue-600 hover:bg-blue-700 rounded-lg text-white font-medium transition">Ver Clientes</a>
      </div>
      <% } %>
    </div>
  </main>

  <!-- FOOTER -->
  <footer class="text-center py-8 text-slate-500 text-sm border-t border-slate-800 mt-12">
    <p>&copy; 2024 Bot de Facturación Electrónica Argentina. Todos los derechos reservados.</p>
  </footer>
</body>
</html>
