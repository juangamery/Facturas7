<h1>📋 Historial de Facturas</h1>

<a href="/admin/facturas/nuevo" class="btn btn-success">+ Nueva Factura</a>

<div class="busqueda">
  <form method="GET" action="/admin/facturas">
    <input type="text" name="q" placeholder="Buscar por cliente o número" value="<%= busqueda %>">
    <button type="submit" class="btn btn-primary">Buscar</button>
  </form>
</div>

<% if (facturas && facturas.length > 0) { %>
<table class="table">
  <thead>
    <tr>
      <th>Número</th>
      <th>Cliente</th>
      <th>Fecha</th>
      <th>Concepto</th>
      <th>Importe</th>
      <th>CAE</th>
      <th>Origen</th>
    </tr>
  </thead>
  <tbody>
    <% facturas.forEach(factura => { %>
    <tr>
      <td><strong><%= factura.numero_factura %></strong></td>
      <td><%= factura.nombre %></td>
      <td><%= new Date(factura.creado_en * 1000).toLocaleDateString('es-AR') %></td>
      <td><%= factura.concepto.substring(0, 30) %>...</td>
      <td>$<%= factura.importe.toLocaleString('es-AR') %></td>
      <td><code><%= factura.cae %></code></td>
      <td>
        <% if (factura.origen === 'texto') { %>
          📝 Texto
        <% } else if (factura.origen === 'imagen') { %>
          📸 Imagen
        <% } else if (factura.origen === 'audio') { %>
          🎤 Audio
        <% } else { %>
          <%= factura.origen %>
        <% } %>
      </td>
    </tr>
    <% }); %>
  </tbody>
</table>

<p style="margin-top: 20px; color: #666;">
  Total: <%= facturas.length %> facturas
</p>

<% } else { %>
<p>No hay facturas registradas</p>
<% } %>

<style>
  .busqueda {
    display: flex;
    gap: 10px;
    margin: 20px 0;
  }

  .busqueda form {
    display: flex;
    gap: 10px;
    width: 100%;
  }

  .busqueda input {
    flex: 1;
  }

  code {
    background: #f5f5f5;
    padding: 2px 6px;
    border-radius: 3px;
    font-family: monospace;
    font-size: 12px;
  }
</style>
