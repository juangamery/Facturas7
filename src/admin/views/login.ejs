<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Facturación Argentina - Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-white flex items-center justify-center min-h-screen">
  <div class="w-full max-w-md px-4">
    <div class="rounded-lg border border-slate-700 bg-slate-800/50 backdrop-blur p-8">
      <h1 class="text-3xl font-bold text-center mb-2">📱 Facturación</h1>
      <p class="text-center text-slate-400 mb-8">Panel de Administración</p>

      <form method="POST" action="/admin/login" class="space-y-4">
        <div>
          <label for="usuario" class="block text-sm font-medium text-slate-300 mb-2">Usuario</label>
          <input type="text" id="usuario" name="usuario" autofocus required class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-blue-500 focus:outline-none" placeholder="admin">
        </div>

        <div>
          <label for="password" class="block text-sm font-medium text-slate-300 mb-2">Contraseña</label>
          <input type="password" id="password" name="password" required class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-blue-500 focus:outline-none" placeholder="••••••••">
        </div>

        <% if (locals.error) { %>
        <div class="p-4 rounded-lg bg-red-900/30 text-red-400 border border-red-800 text-sm">
          <strong>Error:</strong> <%= error %>
        </div>
        <% } %>

        <button type="submit" class="w-full px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition">Entrar</button>
      </form>
    </div>

    <p class="text-center text-slate-500 text-xs mt-6">&copy; 2024 Facturación Electrónica Argentina</p>
  </div>
</body>
</html>
