<h1>👥 Clientes</h1>

<div class="filtros">
  <% const filtroActual = filtro || 'todos'; %>
  <a href="/admin/clientes?filtro=todos" class="btn <%= filtroActual === 'todos' ? 'btn-active' : 'btn-secondary' %>">Todos</a>
  <a href="/admin/clientes?filtro=activos" class="btn <%= filtroActual === 'activos' ? 'btn-active' : 'btn-secondary' %>">Activos</a>
  <a href="/admin/clientes?filtro=vencidos" class="btn <%= filtroActual === 'vencidos' ? 'btn-active' : 'btn-secondary' %>">Vencidos</a>
</div>

<div class="busqueda">
  <form method="GET" action="/admin/clientes">
    <input type="hidden" name="filtro" value="<%= filtro %>">
    <input type="text" name="q" placeholder="Buscar por nombre o CUIT" value="<%= busqueda %>">
    <button type="submit" class="btn btn-primary">Buscar</button>
  </form>
</div>

<a href="/admin/clientes/nuevo" class="btn btn-success">+ Nuevo Cliente</a>

<% if (usuarios && usuarios.length > 0) { %>
<table class="table">
  <thead>
    <tr>
      <th>Nombre</th>
      <th>CUIT</th>
      <th>Plan</th>
      <th>Facturas/Mes</th>
      <th>Vencimiento</th>
      <th>Estado</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% usuarios.forEach(usuario => {
      const vencido = usuario.fecha_vencimiento < Math.floor(Date.now() / 1000);
      const estado = vencido ? 'Vencido' : usuario.activo ? 'Activo' : 'Inactivo';
      const badge = vencido ? 'danger' : usuario.activo ? 'success' : 'warning';
    %>
    <tr>
      <td><a href="/admin/clientes/<%= usuario.id %>"><%= usuario.nombre %></a></td>
      <td><%= usuario.cuit || '-' %></td>
      <td><%= usuario.plan.toUpperCase() %></td>
      <td><%= usuario.facturas_mes_actual %>/<%= usuario.limite_facturas_mes === -1 ? '∞' : usuario.limite_facturas_mes %></td>
      <td><%= usuario.fecha_vencimiento ? new Date(usuario.fecha_vencimiento * 1000).toLocaleDateString('es-AR') : '-' %></td>
      <td><span class="badge badge-<%= badge %>"><%= estado %></span></td>
      <td>
        <a href="/admin/clientes/<%= usuario.id %>" class="btn btn-secondary" style="font-size: 12px;">Ver</a>
      </td>
    </tr>
    <% }); %>
  </tbody>
</table>
<% } else { %>
<p>No hay clientes registrados</p>
<% } %>

<style>
  .filtros {
    margin: 20px 0;
    display: flex;
    gap: 10px;
  }

  .btn-active {
    background: #667eea !important;
    color: white !important;
  }

  .busqueda {
    display: flex;
    gap: 10px;
    margin: 20px 0;
  }

  .busqueda form {
    display: flex;
    gap: 10px;
    width: 100%;
  }

  .busqueda input {
    flex: 1;
  }
</style>
