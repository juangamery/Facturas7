<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nueva Factura - Facturación</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-white">
  <!-- NAVBAR -->
  <nav class="sticky top-0 z-50 border-b border-slate-800 bg-slate-900/95 backdrop-blur">
    <div class="flex items-center justify-between px-6 py-4 max-w-7xl mx-auto w-full">
      <a class="text-xl font-bold text-blue-400" href="/admin/dashboard">📱 Facturación</a>
      <div class="flex gap-2">
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800 transition" href="/admin/dashboard">📊 Dashboard</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800 transition" href="/admin/clientes">👥 Clientes</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-white bg-slate-800 rounded-lg" href="/admin/facturas">📄 Facturas</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-red-400 hover:text-red-300 hover:bg-slate-800 transition" href="/admin/logout">🚪 Salir</a>
      </div>
    </div>
  </nav>

  <!-- MAIN CONTENT -->
  <main class="p-8 max-w-2xl mx-auto">
    <!-- HEADER -->
    <div class="mb-8">
      <a href="/admin/facturas" class="text-blue-400 hover:text-blue-300 flex items-center gap-2 mb-4">← Volver</a>
      <h1 class="text-4xl font-bold text-white mb-2">➕ Nueva Factura</h1>
      <p class="text-slate-400">Crea una factura manualmente</p>
    </div>

    <!-- FORM -->
    <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-8">
      <form id="facturaForm" method="POST" action="/admin/facturas/nuevo" class="space-y-6">

        <!-- CLIENTE -->
        <div>
          <label for="usuario_id" class="block text-sm font-semibold text-white mb-2">
            Cliente <span class="text-red-400">*</span>
          </label>
          <select
            id="usuario_id"
            name="usuario_id"
            required
            class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-600 text-white focus:border-blue-500 focus:outline-none"
          >
            <option value="">Selecciona un cliente...</option>
            <% if (usuarios && usuarios.length > 0) { %>
              <% usuarios.forEach(u => { %>
              <option value="<%= u.id %>"><%= u.nombre %> (<%= u.cuit || 'Sin CUIT' %>)</option>
              <% }); %>
            <% } %>
          </select>
        </div>

        <!-- RAZÓN SOCIAL CLIENTE -->
        <div>
          <label for="razon_social_cliente" class="block text-sm font-semibold text-white mb-2">
            Razón Social Cliente <span class="text-red-400">*</span>
          </label>
          <input
            type="text"
            id="razon_social_cliente"
            name="razon_social_cliente"
            required
            class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-600 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none"
            placeholder="Ej: Juan Pérez SRL"
          >
        </div>

        <!-- CONCEPTO -->
        <div>
          <label for="concepto" class="block text-sm font-semibold text-white mb-2">
            Concepto / Descripción <span class="text-red-400">*</span>
          </label>
          <textarea
            id="concepto"
            name="concepto"
            required
            rows="3"
            class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-600 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none"
            placeholder="Descripción del servicio o producto"
          ></textarea>
        </div>

        <!-- IMPORTE -->
        <div>
          <label for="importe" class="block text-sm font-semibold text-white mb-2">
            Importe ($) <span class="text-red-400">*</span>
          </label>
          <input
            type="number"
            id="importe"
            name="importe"
            required
            step="0.01"
            min="0"
            class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-600 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none"
            placeholder="1000.00"
          >
        </div>

        <!-- BUTTONS -->
        <div class="flex gap-4 pt-6 border-t border-slate-700">
          <button
            type="submit"
            class="px-6 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-semibold transition"
          >
            Crear Factura
          </button>
          <a
            href="/admin/facturas"
            class="px-6 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-white font-semibold transition"
          >
            Cancelar
          </a>
        </div>
      </form>
    </div>

    <!-- INFO -->
    <div class="mt-8 bg-blue-600/10 border border-blue-500/30 rounded-lg p-6">
      <h3 class="font-semibold text-blue-300 mb-2">💡 Información importante</h3>
      <ul class="text-sm text-slate-300 space-y-1">
        <li>• Selecciona el cliente de la lista</li>
        <li>• Completa todos los campos requeridos (*)</li>
        <li>• Se generará automáticamente un PDF y un CAE</li>
      </ul>
    </div>
  </main>

  <!-- FOOTER -->
  <footer class="text-center py-8 text-slate-500 text-sm border-t border-slate-800 mt-12">
    <p>&copy; 2024 Bot de Facturación Electrónica Argentina. Todos los derechos reservados.</p>
  </footer>
</body>
</html>
