<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nuevo Cliente - Facturación</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-white">
  <!-- NAVBAR -->
  <nav class="sticky top-0 z-50 border-b border-slate-800 bg-slate-900/95 backdrop-blur">
    <div class="flex items-center justify-between px-6 py-4 max-w-7xl mx-auto w-full">
      <a class="text-xl font-bold text-blue-400" href="/admin/dashboard">📱 Facturación</a>
      <div class="flex gap-2">
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800 transition" href="/admin/dashboard">📊 Dashboard</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-white bg-slate-800 rounded-lg" href="/admin/clientes">👥 Clientes</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800 transition" href="/admin/facturas">📄 Facturas</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-red-400 hover:text-red-300 hover:bg-slate-800 transition" href="/admin/logout">🚪 Salir</a>
      </div>
    </div>
  </nav>

  <!-- MAIN CONTENT -->
  <main class="p-8 max-w-2xl mx-auto">
    <!-- HEADER -->
    <div class="mb-8">
      <a href="/admin/clientes" class="text-blue-400 hover:text-blue-300 flex items-center gap-2 mb-4">← Volver</a>
      <h1 class="text-4xl font-bold text-white mb-2">➕ Nuevo Cliente</h1>
      <p class="text-slate-400">Agrega un cliente a tu plataforma</p>
    </div>

    <!-- MENSAJE (error / éxito) -->
    <div id="mensaje" class="hidden mb-6 px-4 py-3 rounded-lg text-sm font-medium"></div>

    <!-- FORM -->
    <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-8">
      <form id="form-cliente" method="POST" action="/admin/clientes/nuevo" class="space-y-6">

        <!-- NOMBRE / RAZÓN SOCIAL -->
        <div>
          <label for="nombre" class="block text-sm font-semibold text-white mb-2">
            Nombre / Razón Social <span class="text-red-400">*</span>
          </label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            required
            class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-600 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none"
            placeholder="Ej: Juan Pérez SRL"
          >
        </div>

        <!-- NÚMERO DE WHATSAPP -->
        <div>
          <label for="numero_telefono" class="block text-sm font-semibold text-white mb-2">
            Número de WhatsApp <span class="text-red-400">*</span>
          </label>
          <input
            type="text"
            id="numero_telefono"
            name="numero_telefono"
            required
            class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-600 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none"
            placeholder="54911XXXXXXXXX"
          >
          <p class="text-sm text-slate-400 mt-2">Formato: 54911XXXXXXXXX (con código de país)</p>
        </div>

        <!-- CUIT -->
        <div>
          <label for="cuit" class="block text-sm font-semibold text-white mb-2">CUIT</label>
          <input
            type="text"
            id="cuit"
            name="cuit"
            class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-600 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none"
            placeholder="20-12345678-9"
          >
        </div>

        <!-- RAZÓN SOCIAL (si es diferente) -->
        <div>
          <label for="razon_social" class="block text-sm font-semibold text-white mb-2">Razón Social (si es diferente)</label>
          <input
            type="text"
            id="razon_social"
            name="razon_social"
            class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-600 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none"
            placeholder="Tu Empresa RAZÓN SOCIAL"
          >
        </div>

        <!-- PLAN -->
        <div>
          <label for="plan" class="block text-sm font-semibold text-white mb-2">
            Plan <span class="text-red-400">*</span>
          </label>
          <select
            id="plan"
            name="plan"
            required
            class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-600 text-white focus:border-blue-500 focus:outline-none"
          >
            <option value="basico">Básico ($299/mes - 100 facturas)</option>
            <option value="premium">Premium ($599/mes - Ilimitado)</option>
          </select>
        </div>

        <!-- CHECKBOX BIENVENIDA -->
        <div class="flex items-center gap-3 pt-2">
          <input
            type="checkbox"
            id="enviar_bienvenida"
            name="enviar_bienvenida"
            checked
            class="w-4 h-4 rounded border-slate-600 bg-slate-900 text-blue-600 focus:ring-2 focus:ring-blue-500"
          >
          <label for="enviar_bienvenida" class="text-sm text-slate-300">
            Enviar mensaje de bienvenida por WhatsApp
          </label>
        </div>

        <!-- BUTTONS -->
        <div class="flex gap-4 pt-6 border-t border-slate-700">
          <button
            type="submit"
            class="px-6 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-semibold transition"
          >
            Crear Cliente
          </button>
          <a
            href="/admin/clientes"
            class="px-6 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-white font-semibold transition"
          >
            Cancelar
          </a>
        </div>
      </form>
    </div>
  </main>

  <!-- FOOTER -->
  <footer class="text-center py-8 text-slate-500 text-sm border-t border-slate-800 mt-12">
    <p>&copy; 2024 Bot de Facturación Electrónica Argentina. Todos los derechos reservados.</p>
  </footer>

  <script>
    const form = document.getElementById('form-cliente');
    const msg = document.getElementById('mensaje');

    function mostrar(texto, ok) {
      msg.textContent = texto;
      msg.className = 'mb-6 px-4 py-3 rounded-lg text-sm font-medium ' +
        (ok ? 'bg-green-500/15 text-green-300 border border-green-500/30'
            : 'bg-red-500/15 text-red-300 border border-red-500/30');
      msg.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Creando...';
      try {
        const body = new URLSearchParams(new FormData(form));
        const r = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body,
        });
        const data = await r.json();
        if (r.ok && data.success) {
          mostrar('✅ ' + (data.message || 'Cliente creado'), true);
          setTimeout(() => { window.location.href = '/admin/clientes'; }, 900);
        } else {
          mostrar('❌ ' + (data.error || 'No se pudo crear el cliente'), false);
          btn.disabled = false;
          btn.textContent = 'Crear Cliente';
        }
      } catch (err) {
        mostrar('❌ Error de conexión. Intentá de nuevo.', false);
        btn.disabled = false;
        btn.textContent = 'Crear Cliente';
      }
    });
  </script>
</body>
</html>
