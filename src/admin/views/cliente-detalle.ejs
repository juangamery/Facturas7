<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= usuario.nombre || 'Cliente' %> - Facturación</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-white">
  <!-- NAVBAR -->
  <nav class="sticky top-0 z-50 border-b border-slate-800 bg-slate-900/95 backdrop-blur">
    <div class="flex items-center justify-between px-6 py-4 max-w-7xl mx-auto w-full">
      <a class="text-xl font-bold text-blue-400" href="/admin/dashboard">📱 Facturación</a>
      <div class="flex gap-2">
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800 transition" href="/admin/dashboard">📊 Dashboard</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-white bg-slate-800" href="/admin/clientes">👥 Clientes</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800 transition" href="/admin/facturas">📄 Facturas</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-red-400 hover:text-red-300 hover:bg-slate-800 transition" href="/admin/logout">🚪 Salir</a>
      </div>
    </div>
  </nav>

  <main class="p-8 max-w-4xl mx-auto">
    <a href="/admin/clientes" class="text-blue-400 hover:text-blue-300 flex items-center gap-2 mb-4">← Volver</a>
    <h1 class="text-4xl font-bold mb-6"><%= usuario.nombre || 'Cliente Sin Nombre' %></h1>

    <div id="mensaje" class="hidden mb-6 px-4 py-3 rounded-lg text-sm font-medium"></div>

    <!-- INFO -->
    <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-semibold mb-4 text-slate-200">Información General</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
        <p><span class="text-slate-400">Teléfono:</span> <span class="text-white">+<%= String(usuario.numero_telefono).replace(/^\+/, '') %></span></p>
        <p><span class="text-slate-400">CUIT:</span> <span class="text-white"><%= usuario.cuit || '-' %></span></p>
        <p><span class="text-slate-400">Razón Social:</span> <span class="text-white"><%= usuario.razon_social || '-' %></span></p>
        <p><span class="text-slate-400">Domicilio:</span> <span class="text-white"><%= usuario.domicilio || '-' %></span></p>
        <p><span class="text-slate-400">Condición IVA:</span> <span class="text-white"><%= usuario.condicion_iva || '-' %></span></p>
        <p><span class="text-slate-400">Plan:</span> <span class="text-white"><%= (usuario.plan || 'basico').toUpperCase() %></span></p>
        <p><span class="text-slate-400">Estado:</span>
          <span class="px-2 py-0.5 rounded text-xs font-medium <%= usuario.activo ? 'bg-green-500/20 text-green-300' : 'bg-red-500/20 text-red-300' %>">
            <%= usuario.activo ? 'Activo' : 'Inactivo' %>
          </span>
        </p>
        <p><span class="text-slate-400">Entorno AFIP:</span>
          <span class="px-2 py-0.5 rounded text-xs font-medium <%= usuario.entorno === 'produccion' ? 'bg-purple-500/20 text-purple-300' : 'bg-slate-600/40 text-slate-300' %>">
            <%= (usuario.entorno || 'homologacion').toUpperCase() %>
          </span>
        </p>
        <p><span class="text-slate-400">Vencimiento:</span> <span class="text-white"><%= usuario.fecha_vencimiento ? new Date(usuario.fecha_vencimiento * 1000).toLocaleDateString('es-AR') : '-' %></span></p>
        <p><span class="text-slate-400">Facturas del Mes:</span> <span class="text-white"><%= usuario.facturas_mes_actual || 0 %>/<%= usuario.limite_facturas_mes === -1 ? '∞' : usuario.limite_facturas_mes %></span></p>
      </div>

      <div class="flex flex-wrap gap-3 mt-6 pt-4 border-t border-slate-700">
        <a href="/admin/clientes/<%= usuario.id %>/editar" class="px-4 py-2 rounded-lg font-semibold text-sm bg-slate-700 hover:bg-slate-600 transition">✏️ Editar datos</a>
        <button id="btn-activar" class="px-4 py-2 rounded-lg font-semibold text-sm transition <%= usuario.activo ? 'bg-red-600 hover:bg-red-700' : 'bg-green-600 hover:bg-green-700' %>">
          <%= usuario.activo ? '🚫 Desactivar' : '✅ Activar' %>
        </button>
        <button id="btn-extender" class="px-4 py-2 rounded-lg font-semibold text-sm bg-blue-600 hover:bg-blue-700 transition">📅 Extender 30 días</button>
      </div>
    </div>

    <!-- ENVIAR MENSAJE -->
    <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-semibold mb-2 text-slate-200">✉️ Escribirle por WhatsApp</h2>
      <p class="text-xs text-slate-400 mb-3">Solo funciona si el cliente escribió en las últimas 24hs (ventana abierta). Fuera de eso, Meta requiere una plantilla aprobada.</p>
      <textarea id="msg-texto" rows="3" placeholder="Escribí el mensaje..." class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-600 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none"></textarea>
      <button id="btn-enviar" class="mt-3 px-4 py-2 rounded-lg font-semibold text-sm bg-emerald-600 hover:bg-emerald-700 transition">Enviar mensaje</button>
    </div>

    <!-- FACTURAS -->
    <h2 class="text-xl font-bold mb-4">📄 Últimas Facturas</h2>
    <% if (ultimasFacturas && ultimasFacturas.length > 0) { %>
    <div class="bg-slate-800/50 border border-slate-700 rounded-lg overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-slate-900/60 text-slate-400">
          <tr>
            <th class="px-4 py-3 text-left">Número</th>
            <th class="px-4 py-3 text-left">Fecha</th>
            <th class="px-4 py-3 text-left">Cliente</th>
            <th class="px-4 py-3 text-left">Importe</th>
            <th class="px-4 py-3 text-left">CAE</th>
          </tr>
        </thead>
        <tbody>
          <% ultimasFacturas.forEach(factura => { %>
          <tr class="border-t border-slate-700">
            <td class="px-4 py-3"><%= factura.numero_factura %></td>
            <td class="px-4 py-3 text-slate-300"><%= factura.creado_en ? new Date(factura.creado_en * 1000).toLocaleDateString('es-AR') : '-' %></td>
            <td class="px-4 py-3 text-slate-300"><%= factura.razon_social_cliente %></td>
            <td class="px-4 py-3">$<%= factura.importe %></td>
            <td class="px-4 py-3"><code class="bg-slate-900 px-2 py-1 rounded text-xs text-slate-300"><%= factura.cae %></code></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <p class="text-slate-400">Sin facturas registradas</p>
    <% } %>
  </main>

  <script>
    const uid = '<%= usuario.id %>';
    const msg = document.getElementById('mensaje');

    function mostrar(texto, ok) {
      msg.textContent = texto;
      msg.className = 'mb-6 px-4 py-3 rounded-lg text-sm font-medium ' +
        (ok ? 'bg-green-500/15 text-green-300 border border-green-500/30'
            : 'bg-red-500/15 text-red-300 border border-red-500/30');
      msg.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    async function accion(url, body, okMsg, reload) {
      try {
        const r = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body ? new URLSearchParams(body) : undefined,
        });
        const data = await r.json();
        if (r.ok && data.success) {
          mostrar('✅ ' + okMsg, true);
          if (reload) setTimeout(() => location.reload(), 900);
          return true;
        }
        mostrar('❌ ' + (data.error || 'Error'), false);
        return false;
      } catch (e) {
        mostrar('❌ Error de conexión', false);
        return false;
      }
    }

    document.getElementById('btn-activar').addEventListener('click', () =>
      accion('/admin/clientes/' + uid + '/activar', null, 'Estado actualizado', true));

    document.getElementById('btn-extender').addEventListener('click', () =>
      accion('/admin/clientes/' + uid + '/extender', { dias: 30 }, 'Suscripción extendida 30 días', true));

    document.getElementById('btn-enviar').addEventListener('click', async () => {
      const texto = document.getElementById('msg-texto').value.trim();
      if (!texto) { mostrar('❌ Escribí un mensaje', false); return; }
      const btn = document.getElementById('btn-enviar');
      btn.disabled = true; btn.textContent = 'Enviando...';
      const ok = await accion('/admin/clientes/' + uid + '/mensaje', { texto }, 'Mensaje enviado', false);
      if (ok) document.getElementById('msg-texto').value = '';
      btn.disabled = false; btn.textContent = 'Enviar mensaje';
    });
  </script>
</body>
</html>
