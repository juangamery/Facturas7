<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#2563eb">
  <title><%= title %> - Facturación Argentina</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { @apply bg-slate-950 text-white; }
  </style>
</head>
<body class="bg-slate-950">
  <!-- NAVBAR -->
  <nav class="sticky top-0 z-50 border-b border-slate-800 bg-slate-900/95 backdrop-blur">
    <div class="flex items-center justify-between px-6 py-4 max-w-7xl mx-auto w-full">
      <a class="text-xl font-bold text-blue-500" href="/admin/dashboard">
        📱 Facturación
      </a>
      <div class="flex gap-1">
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800 transition" href="/admin/dashboard">📊 Dashboard</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800 transition" href="/admin/clientes">👥 Clientes</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800 transition" href="/admin/facturas">📄 Facturas</a>
        <a class="px-4 py-2 rounded-lg text-sm font-medium text-red-400 hover:text-red-300 hover:bg-slate-800 transition" href="/admin/logout">🚪 Salir</a>
      </div>
    </div>
  </nav>

  <!-- CONTENIDO PRINCIPAL -->
  <main class="flex-1 p-8 max-w-7xl w-full mx-auto">
    <% if (locals.error) { %>
    <div class="mb-6 p-4 rounded-lg bg-red-900/30 text-red-400 border border-red-800">
      <strong>Error:</strong> <%= error %>
    </div>
    <% } %>

    <% if (locals.success) { %>
    <div class="mb-6 p-4 rounded-lg bg-green-900/30 text-green-400 border border-green-800">
      <%= success %>
    </div>
    <% } %>

    <%- body %>
  </main>

  <!-- FOOTER -->
  <footer class="text-center py-4 text-slate-500 text-sm border-t border-slate-800">
    <p>&copy; 2024 Bot de Facturación Electrónica Argentina. Todos los derechos reservados.</p>
  </footer>
</body>
</html>
