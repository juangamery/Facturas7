{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "functions": {
    "src/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "env": [
    "SUPABASE_URL",
    "SUPABASE_KEY",
    "GROQ_API_KEY",
    "MAIL_HOST",
    "MAIL_USER",
    "MAIL_PASS",
    "MAIL_PORT",
    "MAIL_FROM",
    "MAIL_IMAP_HOST",
    "MAIL_IMAP_PORT",
    "ADMIN_USER",
    "ADMIN_PASSWORD",
    "SESSION_SECRET",
    "BASE_URL"
  ]
}
